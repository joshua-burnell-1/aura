{
  "expo": {
    "name": "aura",
    "slug": "aura",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "aura",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshua.burnell.aura",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Aura discovers nearby devices to help you organize and troubleshoot them.",
        "NSMicrophoneUsageDescription": "Aura listens only when you press the mic button so you can ask questions about your devices.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.joshua.burnell.aura",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Aura to record audio for voice commands."
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [],
          "bluetoothAlwaysPermission": "Allow Aura to discover and identify nearby Bluetooth devices."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bf52cb39-1d0c-4aa4-a2a7-6bb632fd5948"
      }
    }
  }
}
